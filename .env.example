# Variables de entorno — EJEMPLO
# Copiar este archivo a .env y completar con los valores reales.
# NUNCA subir el archivo .env al repositorio.

# =============================================
# DB Records (PostgreSQL)
# =============================================
DB_RECORDS_HOST=
DB_RECORDS_PORT=5432
DB_RECORDS_USER=
DB_RECORDS_PASS=
DB_RECORDS_NAME=records

# =============================================
# Soldef (PostgreSQL)
# =============================================
DB_SOLDEF_HOST=
DB_SOLDEF_PORT=5432
DB_SOLDEF_USER=
DB_SOLDEF_PASS=
DB_SOLDEF_NAME=soldef

# =============================================
# Incidencias / Mesa Westnet (PostgreSQL)
# =============================================
DB_MESA_HOST=
DB_MESA_PORT=5432
DB_MESA_USER=
DB_MESA_PASS=
DB_MESA_NAME=incidencias

# =============================================
# Incidencias / Mesa Bigway (PostgreSQL)
# =============================================
DB_MESA_BW_HOST=
DB_MESA_BW_PORT=5432
DB_MESA_BW_USER=
DB_MESA_BW_PASS=
DB_MESA_BW_NAME=incidencias

# =============================================
# Gestion Westnet (MySQL)
# =============================================
DB_GESTION_HOST=
DB_GESTION_USER=
DB_GESTION_PASS=
DB_GESTION_NAME=westnet_2

# =============================================
# Gestion Bigway (MySQL)
# =============================================
DB_GESTION_BW_HOST=
DB_GESTION_BW_USER=
DB_GESTION_BW_PASS=
DB_GESTION_BW_NAME=gestion_bigway

# =============================================
# Napear (MySQL)
# =============================================
DB_NAP_HOST=
DB_NAP_USER=
DB_NAP_PASS=
DB_NAP_NAME=napear

# =============================================
# Odoo DB local (PostgreSQL)
# =============================================
DB_ODOO_HOST=
DB_ODOO_PORT=5432
DB_ODOO_USER=
DB_ODOO_PASS=
DB_ODOO_NAME=datosodoo

# =============================================
# Odoo API (XML-RPC)
# =============================================
ODOO_API_URL=http://172.16.210.121:8069
ODOO_API_DB=datosodoo
ODOO_API_USER=mi_usuario_odoo
ODOO_API_PASS=mi_password_o_api_key

# =============================================
# Opciones de ejecucion
# =============================================
# true = simula sin escribir en DB
DRY_RUN=false
